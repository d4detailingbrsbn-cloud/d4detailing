<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>D4 Detailing – Driven by Detail</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;900&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --red: #CC1F1F; --red-bright: #E52222; --red-dark: #8B0000;
    --black: #0A0A0A; --black2: #111111; --black3: #1A1A1A;
    --silver: #C8C8C8; --silver2: #E8E8E8; --white: #FFFFFF;
    --font-head: 'Barlow Condensed', sans-serif; --font-body: 'Barlow', sans-serif;
  }
  html { scroll-behavior: smooth; }
  body { background: var(--black); color: var(--white); font-family: var(--font-body); }
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(10,10,10,0.95); border-bottom: 1px solid var(--red-dark); display: flex; align-items: center; justify-content: space-between; padding: 0 2rem; height: 64px; backdrop-filter: blur(8px); }
  .nav-logo { font-family: var(--font-head); font-size: 1.5rem; font-weight: 900; letter-spacing: 2px; color: var(--white); }
  .nav-logo span { color: var(--red-bright); }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a { font-family: var(--font-head); font-size: 0.95rem; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; text-decoration: none; color: var(--silver); transition: color 0.2s; }
  .nav-links a:hover { color: var(--red-bright); }
  .hero { min-height: 100vh; background: linear-gradient(160deg, #0A0A0A 0%, #1a0000 50%, #0A0A0A 100%); display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 6rem 2rem 4rem; position: relative; overflow: hidden; }
  .hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 60% 50% at 50% 60%, rgba(204,31,31,0.18) 0%, transparent 70%); }
  .hero-tag { font-family: var(--font-head); font-size: 0.85rem; font-weight: 700; letter-spacing: 4px; text-transform: uppercase; color: var(--red-bright); border: 1px solid var(--red-dark); padding: 6px 20px; margin-bottom: 1.5rem; display: inline-block; }
  .hero h1 { font-family: var(--font-head); font-size: clamp(3.5rem, 10vw, 7rem); font-weight: 900; line-height: 0.9; letter-spacing: 2px; text-transform: uppercase; position: relative; z-index: 1; }
  .hero h1 .d4 { color: var(--red-bright); display: block; }
  .hero h1 .detailing { color: var(--white); display: block; }
  .hero-sub { font-family: var(--font-head); font-size: 1rem; font-weight: 600; letter-spacing: 6px; text-transform: uppercase; color: var(--silver); margin: 1rem 0 2.5rem; }
  .hero-divider { width: 80px; height: 2px; background: var(--red-bright); margin: 0 auto 2rem; }
  .hero-desc { font-size: 1.1rem; color: var(--silver); max-width: 480px; line-height: 1.7; margin: 0 auto 2.5rem; }
  .btn-group { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red-bright); color: var(--white); font-family: var(--font-head); font-weight: 700; font-size: 0.95rem; letter-spacing: 2px; text-transform: uppercase; padding: 14px 36px; border: none; cursor: pointer; text-decoration: none; display: inline-block; transition: background 0.2s, transform 0.1s; clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%); }
  .btn-primary:hover { background: var(--red); transform: translateY(-1px); }
  .btn-secondary { background: transparent; color: var(--silver); font-family: var(--font-head); font-weight: 700; font-size: 0.95rem; letter-spacing: 2px; text-transform: uppercase; padding: 13px 36px; border: 1px solid var(--silver); cursor: pointer; text-decoration: none; display: inline-block; transition: border-color 0.2s, color 0.2s; clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%); }
  .btn-secondary:hover { border-color: var(--red-bright); color: var(--red-bright); }
  section { padding: 5rem 2rem; }
  .section-label { font-family: var(--font-head); font-size: 0.8rem; font-weight: 700; letter-spacing: 4px; text-transform: uppercase; color: var(--red-bright); margin-bottom: 0.5rem; }
  .section-title { font-family: var(--font-head); font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; text-transform: uppercase; color: var(--white); letter-spacing: 1px; margin-bottom: 0.5rem; }
  .section-title span { color: var(--red-bright); }
  .section-line { width: 48px; height: 3px; background: var(--red-bright); margin: 1rem 0 2.5rem; }
  .section-center { text-align: center; }
  .section-center .section-line { margin: 1rem auto 2.5rem; }
  .container { max-width: 1100px; margin: 0 auto; }
  .why-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; margin-top: 1rem; }
  .why-card { background: var(--black3); border: 1px solid #2a0000; border-top: 3px solid var(--red-bright); padding: 2rem 1.5rem; transition: border-color 0.2s; }
  .why-card:hover { border-top-color: var(--red); }
  .why-icon { font-size: 2rem; margin-bottom: 1rem; }
  .why-card h3 { font-family: var(--font-head); font-size: 1.2rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--white); margin-bottom: 0.5rem; }
  .why-card p { font-size: 0.9rem; color: var(--silver); line-height: 1.6; }
  .services-bg { background: var(--black2); }
  .services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; }
  .service-card { background: var(--black3); border: 1px solid #2a0000; padding: 2rem; position: relative; overflow: hidden; transition: transform 0.2s; }
  .service-card:hover { transform: translateY(-3px); }
  .service-card::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: var(--red-bright); }
  .service-badge { display: inline-block; background: var(--red-dark); color: var(--silver2); font-family: var(--font-head); font-size: 0.75rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; padding: 4px 12px; margin-bottom: 1rem; }
  .service-card h3 { font-family: var(--font-head); font-size: 1.4rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--white); margin-bottom: 0.75rem; }
  .service-card ul { list-style: none; margin-bottom: 1.5rem; }
  .service-card ul li { font-size: 0.9rem; color: var(--silver); padding: 4px 0; border-bottom: 1px solid #2a2a2a; display: flex; align-items: center; gap: 8px; }
  .service-card ul li::before { content: '—'; color: var(--red-bright); font-weight: 700; }
  .price-row { display: flex; align-items: baseline; gap: 0.5rem; }
  .price-from { font-size: 0.8rem; color: var(--silver); font-family: var(--font-head); letter-spacing: 1px; text-transform: uppercase; }
  .price-amount { font-family: var(--font-head); font-size: 2rem; font-weight: 900; color: var(--red-bright); }
  .popular-badge { position: absolute; top: 1.25rem; right: 1.25rem; background: var(--red-bright); color: white; font-family: var(--font-head); font-size: 0.7rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; padding: 4px 10px; }
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; }
  @media (max-width: 700px) { .contact-grid { grid-template-columns: 1fr; } .nav-links { display: none; } }
  .contact-info h3 { font-family: var(--font-head); font-size: 1.1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: var(--red-bright); margin-bottom: 1rem; }
  .contact-item { display: flex; align-items: center; gap: 1rem; padding: 1rem 0; border-bottom: 1px solid #2a2a2a; }
  .contact-icon { width: 40px; height: 40px; background: #1a0000; border: 1px solid var(--red-dark); display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0; }
  .contact-item span { font-size: 0.9rem; color: var(--silver); }
  .contact-item strong { display: block; font-size: 1rem; color: var(--white); font-weight: 500; }
  .contact-form { display: flex; flex-direction: column; gap: 1rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .contact-form input, .contact-form select, .contact-form textarea { background: var(--black3); border: 1px solid #333; color: var(--white); font-family: var(--font-body); font-size: 0.95rem; padding: 12px 16px; width: 100%; transition: border-color 0.2s; outline: none; }
  .contact-form input:focus, .contact-form select:focus, .contact-form textarea:focus { border-color: var(--red-bright); }
  .contact-form input::placeholder, .contact-form textarea::placeholder { color: #555; }
  .contact-form select { color: #555; }
  .contact-form select option { color: var(--white); background: var(--black3); }
  .contact-form textarea { height: 120px; resize: vertical; }
  .form-submit { background: var(--red-bright); color: var(--white); font-family: var(--font-head); font-weight: 700; font-size: 1rem; letter-spacing: 2px; text-transform: uppercase; padding: 14px; border: none; cursor: pointer; transition: background 0.2s; clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%); }
  .form-submit:hover { background: var(--red); }
  .success-msg { display: none; background: #1a3a1a; border: 1px solid #2a6a2a; color: #7aff7a; padding: 1rem; text-align: center; font-family: var(--font-head); font-size: 1.1rem; letter-spacing: 1px; }
  footer { background: var(--black2); border-top: 1px solid var(--red-dark); text-align: center; padding: 2rem; }
  footer .logo { font-family: var(--font-head); font-size: 1.5rem; font-weight: 900; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 0.5rem; }
  footer .logo span { color: var(--red-bright); }
  footer p { font-size: 0.8rem; color: #555; letter-spacing: 1px; }
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .reveal.visible { opacity: 1; transform: none; }
</style>
</head>
<body>

<nav>
  <div class="nav-logo"><span>D4</span> DETAILING</div>
  <ul class="nav-links">
    <li><a href="#services">Services</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <a href="#contact" class="btn-primary" style="padding:10px 24px; font-size:0.85rem;">Book Now</a>
</nav>

<section class="hero" id="home">
  <div class="hero-tag">Mobile Detailing</div>
  <h1><span class="d4">D4</span><span class="detailing">Detailing</span></h1>
  <p class="hero-sub">— Driven by Detail —</p>
  <div class="hero-divider"></div>
  <p class="hero-desc">Professional mobile car detailing that comes to you. We bring showroom shine to your driveway, workplace, or anywhere in between.</p>
  <div class="btn-group">
    <a href="#services" class="btn-primary">View Services</a>
    <a href="#contact" class="btn-secondary">Get a Quote</a>
  </div>
</section>

<section id="why">
  <div class="container">
    <div class="section-center reveal">
      <p class="section-label">Why Choose Us</p>
      <h2 class="section-title">The <span>D4</span> Difference</h2>
      <div class="section-line"></div>
    </div>
    <div class="why-grid">
      <div class="why-card reveal"><div class="why-icon">🚗</div><h3>We Come to You</h3><p>No need to drive anywhere. We bring all equipment and supplies directly to your location.</p></div>
      <div class="why-card reveal"><div class="why-icon">✨</div><h3>Premium Products</h3><p>We only use professional-grade detailing products for a finish that lasts and protects.</p></div>
      <div class="why-card reveal"><div class="why-icon">🛡️</div><h3>Fully Insured</h3><p>Your vehicle is in safe hands. We're fully insured so you can have complete peace of mind.</p></div>
      <div class="why-card reveal"><div class="why-icon">⭐</div><h3>100% Satisfaction</h3><p>Not happy? We'll make it right. Your satisfaction is our guarantee, every single time.</p></div>
    </div>
  </div>
</section>

<section id="services" class="services-bg">
  <div class="container">
    <div class="reveal">
      <p class="section-label">What We Offer</p>
      <h2 class="section-title">Our <span>Services</span></h2>
      <div class="section-line"></div>
    </div>
    <div class="services-grid">
      <div class="service-card reveal">
        <span class="service-badge">Essential</span>
        <h3>Basic Wash &amp; Vac</h3>
        <ul>
          <li>Exterior hand wash &amp; dry</li>
          <li>Interior vacuum</li>
          <li>Window clean</li>
          <li>Tyre shine</li>
        </ul>
        <div class="price-row"><span class="price-from">From</span><span class="price-amount">$100</span></div>
      </div>
      <div class="service-card reveal" style="border-color: var(--red-dark);">
        <span class="popular-badge">Most Popular</span>
        <span class="service-badge">Premium</span>
        <h3>Full Detail</h3>
        <ul>
          <li>Everything in Basic</li>
          <li>Interior deep clean &amp; condition</li>
          <li>Paint decontamination</li>
          <li>Hand wax &amp; polish</li>
          <li>Engine bay clean</li>
        </ul>
        <div class="price-row"><span class="price-from">From</span><span class="price-amount">$199</span></div>
      </div>
    </div>
    <p style="color: #555; font-size: 0.85rem; margin-top: 1.5rem;">* Prices vary by vehicle size. Contact us for an exact quote.</p>
  </div>
</section>

<section id="contact">
  <div class="container">
    <div class="reveal">
      <p class="section-label">Get in Touch</p>
      <h2 class="section-title">Book a <span>Detail</span></h2>
      <div class="section-line"></div>
    </div>
    <div class="contact-grid">
      <div class="reveal">
        <h3>Contact Info</h3>
        <div class="contact-item">
          <div class="contact-icon">📞</div>
          <div><span>Phone / SMS</span><strong>0426 357 582</strong></div>
        </div>
        <div class="contact-item">
          <div class="contact-icon">📧</div>
          <div><span>Email</span><strong>d4detailingbrsbn@gmail.com</strong></div>
        </div>
        <div class="contact-item">
          <div class="contact-icon">📍</div>
          <div><span>Service Area</span><strong>Brisbane &amp; Surrounds, QLD</strong></div>
        </div>
        <div class="contact-item">
          <div class="contact-icon">🕐</div>
          <div><span>Hours</span><strong>Mon – Sat: 7am – 6pm</strong></div>
        </div>
      </div>
      <div class="reveal">
        <div class="success-msg" id="successMsg">✓ Enquiry sent! We'll be in touch soon.</div>
        <form class="contact-form" id="enquiryForm">
          <div class="form-row">
            <input type="text" name="name" placeholder="Your Name" required>
            <input type="tel" name="phone" placeholder="Phone Number" required>
          </div>
          <input type="email" name="email" placeholder="Email Address" required>
          <select name="service" required>
            <option value="" disabled selected>Select a Service</option>
            <option>Basic Wash &amp; Vac – from $100</option>
            <option>Full Detail – from $199</option>
            <option>Not sure – send me a quote</option>
          </select>
          <select name="vehicle" required>
            <option value="" disabled selected>Vehicle Type</option>
            <option>Small Car / Hatchback</option>
            <option>Sedan</option>
            <option>SUV / 4WD</option>
            <option>Ute / Van</option>
          </select>
          <textarea name="notes" placeholder="Any additional notes? (e.g. pet hair, heavy staining, preferred date)"></textarea>
          <button type="submit" class="form-submit">Send Enquiry →</button>
        </form>
      </div>
    </div>
  </div>
</section>

<footer>
  <p class="logo"><span>D4</span> DETAILING</p>
  <p>— DRIVEN BY DETAIL —</p>
  <p style="margin-top:1rem;">© 2026 D4 Detailing. All rights reserved.</p>
</footer>

<script>
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  reveals.forEach(el => observer.observe(el));

  document.getElementById('enquiryForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const form = e.target;
    const btn = form.querySelector('.form-submit');
    btn.textContent = 'Sending...';
    btn.disabled = true;

    const data = new FormData(form);

    try {
      const response = await fetch('https://formspree.io/f/mjglopvv', {
        method: 'POST',
        body: data,
        headers: { 'Accept': 'application/json' }
      });

      if (response.ok) {
        form.style.display = 'none';
        document.getElementById('successMsg').style.display = 'block';
      } else {
        btn.textContent = 'Error – Try Again';
        btn.disabled = false;
      }
    } catch (err) {
      btn.textContent = 'Error – Try Again';
      btn.disabled = false;
    }
  });
</script>
</body>
</html>
